<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base madera caoba -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5D3A1A"/>
        </shape>
    </item>

    <!-- Veta horizontal 1 -->
    <item android:top="40dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#15000000"
                android:endColor="#00000000"/>
            <size android:height="6dp"/>
        </shape>
    </item>

    <!-- Veta horizontal 2 -->
    <item android:top="110dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#20000000"
                android:endColor="#00000000"/>
            <size android:height="4dp"/>
        </shape>
    </item>

    <!-- Veta horizontal 3 -->
    <item android:top="200dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#18000000"
                android:endColor="#00000000"/>
            <size android:height="8dp"/>
        </shape>
    </item>

    <!-- Veta horizontal 4 -->
    <item android:top="310dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#12000000"
                android:endColor="#00000000"/>
            <size android:height="5dp"/>
        </shape>
    </item>

    <!-- Veta horizontal 5 -->
    <item android:top="430dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#22000000"
                android:endColor="#00000000"/>
            <size android:height="6dp"/>
        </shape>
    </item>

    <!-- Overlay cálido para dar profundidad -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#25C68A2E"
                android:endColor="#10A0521E"/>
        </shape>
    </item>

    <!-- Brillo izquierdo sutil -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>
