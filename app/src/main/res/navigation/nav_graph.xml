<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.pb.ui.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.pb.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_instrucciones"
            app:destination="@id/instruccionesFragment"/>
        <action
            android:id="@+id/action_home_to_retos"
            app:destination="@id/retosFragment"/>
        <action
            android:id="@+id/action_home_to_mostrar_reto"
            app:destination="@id/mostrarRetoFragment"/>
    </fragment>

    <fragment
        android:id="@+id/instruccionesFragment"
        android:name="com.example.pb.ui.instrucciones.InstruccionesFragment"
        android:label="Instrucciones"/>

    <fragment
        android:id="@+id/retosFragment"
        android:name="com.example.pb.ui.retos.RetosFragment"
        android:label="Retos"/>

    <fragment
        android:id="@+id/mostrarRetoFragment"
        android:name="com.example.pb.ui.retos.MostrarRetoFragment"
        android:label="Mostrar Reto"/>

</navigation>
