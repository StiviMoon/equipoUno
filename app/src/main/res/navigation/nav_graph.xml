<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.pb.ui.splash.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>

    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.pb.ui.login.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.pb.ui.register.RegisterFragment"
        android:label="Registro">

        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.pb.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_instrucciones"
            app:destination="@id/instruccionesFragment"/>
        <action
            android:id="@+id/action_home_to_retos"
            app:destination="@id/retosFragment"/>
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/instruccionesFragment"
        android:name="com.example.pb.ui.instrucciones.InstruccionesFragment"
        android:label="Instrucciones"/>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.pb.ui.register.RegisterFragment"
        android:label="Register">

        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />

    </fragment>

    <fragment
        android:id="@+id/retosFragment"
        android:name="com.example.pb.ui.retos.RetosFragment"
        android:label="Retos"/>

</navigation>
