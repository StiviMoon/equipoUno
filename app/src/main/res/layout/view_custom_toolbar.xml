<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:id="@+id/toolbarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_toolbar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnRate"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_star"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_rate"/>

            <ImageButton
                android:id="@+id/btnAudio"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_audio_on"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_audio"/>

            <ImageButton
                android:id="@+id/btnInstructions"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_instrucciones"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_instructions"/>

            <ImageButton
                android:id="@+id/btnChallenges"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_retos"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_challenges"/>

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_compartir"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/cd_share"/>

        </LinearLayout>
    </LinearLayout>

</merge>
