<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <!-- Toolbar -->
    <com.example.pb.ui.toolbar.CustomToolbarView
        android:id="@+id/customToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título del juego -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_title"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:textAllCaps="true"
        android:alpha="0.4"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/customToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botella — tamaño generoso, sin cortes -->
    <ImageView
        android:id="@+id/ivBottle"
        android:layout_width="120dp"
        android:layout_height="336dp"
        android:src="@drawable/ic_bottle"
        android:scaleType="fitCenter"
        android:contentDescription="@string/cd_bottle"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toTopOf="@id/btnPress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"/>

    <!-- Contador sobre la botella -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="3"
        android:textColor="@color/orange"
        android:textSize="42sp"
        android:textStyle="bold"
        android:background="@drawable/bg_countdown"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/ivBottle"
        app:layout_constraintBottom_toBottomOf="@id/ivBottle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón pill -->
    <TextView
        android:id="@+id/btnPress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_btn_spin"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:background="@drawable/btn_press_bg"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
